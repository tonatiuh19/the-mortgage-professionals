# ========================================
# CONVERSATIONS & COMMUNICATION SETUP
# ========================================

# Twilio Configuration for SMS/WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
# For WhatsApp (optional, will use TWILIO_PHONE_NUMBER if not set)
TWILIO_WHATSAPP_NUMBER=+1234567890

# Email Configuration (SMTP)
SMTP_HOST=mail.hostgator.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@yourdomain.com
SMTP_PASSWORD=your_email_password
SMTP_FROM="Your Company Name <your_email@yourdomain.com>"

# ========================================
# SETUP INSTRUCTIONS
# ========================================

# 1. TWILIO SETUP:
#    - Create account at https://www.twilio.com/
#    - Get Account SID and Auth Token from Console
#    - Purchase a phone number for SMS
#    - For WhatsApp: Apply for WhatsApp Business API access
#    - Add these credentials to your .env file

# 2. EMAIL SETUP (HostGator):
#    - Use your HostGator email credentials
#    - SMTP settings are usually:
#      - Host: mail.yourdomain.com (or mail.hostgator.com)
#      - Port: 587 (TLS) or 465 (SSL)
#      - Security: TLS/STARTTLS

# 3. DATABASE:
#    - The conversation tables are already created per schema.sql
#    - Templates table has sample templates loaded
#    - No additional database setup required

# ========================================
# FEATURES ENABLED
# ========================================

# ✅ SMS messaging via Twilio
# ✅ WhatsApp messaging via Twilio Business API
# ✅ Email messaging via SMTP
# ✅ Template system with variable replacement
# ✅ Conversation threading and management
# ✅ Real-time conversation statistics
# ✅ Message status tracking (pending, sent, delivered, failed)
# ✅ Cost tracking for SMS/WhatsApp messages
# ✅ Audit logging for all communications
# ✅ Modern, responsive UI for conversations management

# ========================================
# COST TRACKING
# ========================================

# SMS costs are automatically tracked from Twilio responses
# WhatsApp messaging costs depend on your Twilio pricing plan
# Email costs are not tracked (typically free with hosting)

# ========================================
# SECURITY NOTES
# ========================================

# - All communications are stored securely in database
# - Template variables prevent injection attacks
# - Phone numbers are normalized and validated
# - Email addresses are validated before sending
# - All API calls require broker authentication
# - Audit logs track all communication activities

# ========================================
# ADMIN USAGE
# ========================================

# Navigate to /admin/conversations to:
# - View all conversation threads
# - Filter by status, priority, or search clients
# - Send new SMS, WhatsApp, or Email messages
# - Reply to existing conversation threads
# - Use templates for common messages
# - Track message delivery status
# - View conversation statistics
# - Manage conversation priorities and tags